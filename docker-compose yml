version: '3.8'

services:
  mongodb:
    image: mongo:6
    container_name: corpercompass-mongodb
    restart: unless-stopped
    ports:
      - "27017:27017"
    environment:
      MONGO_INITDB_ROOT_USERNAME: root
      MONGO_INITDB_ROOT_PASSWORD: example
      MONGO_INITDB_DATABASE: corpercompass
    volumes:
      - mongo-data:/data/db

  backend:
    build: ./corpercompass-backend
    container_name: corpercompass-backend
    restart: unless-stopped
    ports:
      - "5000:5000"
    environment:
      NODE_ENV: production
      PORT: 5000
      MONGO_URI: mongodb://root:example@mongodb:27017/corpercompass?authSource=admin
      JWT_SECRET: your_jwt_secret_here_change_in_production
    depends_on:
      - mongodb

  frontend:
    build: ./corpercompass-frontend
    container_name: corpercompass-frontend
    restart: unless-stopped
    ports:
      - "80:80"
    depends_on:
      - backend

volumes:
  mongo-data:
